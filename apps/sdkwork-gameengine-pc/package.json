    "@sdkwork/auth-runtime-pc-react": "workspace:*",
    "@sdkwork/iam-contracts": "workspace:*",
    "@sdkwork/iam-runtime": "workspace:*",
    "@sdkwork/runtime-bootstrap": "workspace:*",
    "@sdkwork/sdk-common": "workspace:*",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "catalog:",
    "tailwindcss": "^4.1.14",
    "i18next": "^25.8.17",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "next-themes": "^0.4.6",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-i18next": "catalog:",
    "react-router": "catalog:",
    "react-router-dom": "catalog:",
    "@sdkwork/gameengine-app-sdk": "workspace:*",
