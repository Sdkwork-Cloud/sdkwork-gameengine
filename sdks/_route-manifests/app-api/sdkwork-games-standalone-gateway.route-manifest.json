{
  "schemaVersion": 1,
  "kind": "sdkwork.route.manifest",
  "packageName": "sdkwork-gameengine-standalone-gateway",
  "surface": "app-api",
  "owner": "sdkwork-games",
  "domain": "game",
  "capability": "catalog",
  "apiAuthority": "sdkwork-gameengine-app-api",
  "sdkFamily": "sdkwork-gameengine-app-sdk",
  "prefix": "/app/v3/api",
  "source": {
    "crateRoot": "crates/sdkwork-gameengine-standalone-gateway",
    "crateImport": "sdkwork_gameengine_standalone_gateway",
    "openapiAuthority": "apis/app-api/game/games-app-api.openapi.json"
  },
  "routes": [
    {
      "method": "GET",
      "path": "/health",
      "operationId": "games.health.retrieve",
      "tags": ["health"],
      "requestContext": "WebRequestContext",
      "apiSurface": "app-api",
      "auth": { "mode": "public" },
      "handler": { "module": "crate", "name": "games_health_check" },
      "schemas": { "request": null, "response": "GamesHealthResponse", "problem": "ProblemDetail" },
      "ownership": { "owner": "sdkwork-games", "apiAuthority": "sdkwork-gameengine-app-api" },
      "source": { "file": "apis/app-api/game/games-app-api.openapi.json" }
    },
    {
      "method": "GET",
      "path": "/ready",
      "operationId": "games.ready.retrieve",
      "tags": ["health"],
      "requestContext": "WebRequestContext",
      "apiSurface": "app-api",
      "auth": { "mode": "public" },
      "handler": { "module": "crate", "name": "games_ready_check" },
      "schemas": { "request": null, "response": "GamesHealthResponse", "problem": "ProblemDetail" },
      "ownership": { "owner": "sdkwork-games", "apiAuthority": "sdkwork-gameengine-app-api" },
      "source": { "file": "apis/app-api/game/games-app-api.openapi.json" }
    }
  ]
}
