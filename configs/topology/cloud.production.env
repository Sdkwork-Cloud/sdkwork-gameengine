SDKWORK_GAMES_PROFILE_ID=cloud.production
SDKWORK_GAMES_DEPLOYMENT_PROFILE=cloud
SDKWORK_GAMES_ENVIRONMENT=production
SDKWORK_GAMES_RUNTIME_TARGET=container
VITE_SDKWORK_GAMES_DEPLOYMENT_PROFILE=cloud
VITE_SDKWORK_GAMES_RUNTIME_TARGET=browser
SDKWORK_GAMES_APPLICATION_PUBLIC_INGRESS_BIND=0.0.0.0:8095
SDKWORK_GAMES_APPLICATION_PUBLIC_HTTP_URL=https://gameengine.sdkwork.com
VITE_SDKWORK_GAMES_APPLICATION_PUBLIC_HTTP_URL=https://gameengine.sdkwork.com
SDKWORK_GAMES_PLATFORM_API_GATEWAY_AUTOSTART=true
SDKWORK_API_CLOUD_GATEWAY_BIND=0.0.0.0:3900
SDKWORK_GAMES_PLATFORM_API_GATEWAY_HTTP_URL=https://api.sdkwork.com
VITE_SDKWORK_GAMES_PLATFORM_API_GATEWAY_HTTP_URL=https://api.sdkwork.com
SDKWORK_API_CLOUD_GATEWAY_CONFIG=configs/sdkwork-api-cloud-gateway.gameengine.production.toml
SDKWORK_GAMES_DATABASE_ENGINE=postgresql
SDKWORK_GAMES_DATABASE_HOST=db.games.internal
SDKWORK_GAMES_DATABASE_PORT=5432
SDKWORK_GAMES_DATABASE_NAME=sdkwork_games_prod
SDKWORK_GAMES_DATABASE_SCHEMA=sdkwork_games_prod
SDKWORK_GAMES_DATABASE_USERNAME=sdkwork_games
SDKWORK_GAMES_DATABASE_PASSWORD_FILE=/run/secrets/sdkwork/games/database-password
SDKWORK_GAMES_DATABASE_SSL_MODE=require
SDKWORK_GAMES_DATABASE_MAX_CONNECTIONS=32
SDKWORK_GAMES_DATABASE_AUTO_MIGRATE=false
