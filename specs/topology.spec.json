{
  "schemaVersion": 5,
  "kind": "sdkwork.app.topology",
  "appId": "sdkwork-gameengine",
  "archetype": "application-http-gateway",
  "profileRoot": "configs/topology",
  "profilePattern": "{deploymentProfile}.{environment}.env",
  "vocabulary": {
    "deploymentProfile": {
      "allowed": [
        "standalone",
        "cloud"
      ]
    },
    "environment": {
      "allowed": [
        "development",
        "production"
      ]
    }
  },
  "defaults": {
    "developmentProfileId": "standalone.development",
    "productionProfileId": "cloud.production",
    "desktopBuildProfileId": "standalone.production",
    "gatewayBind": "127.0.0.1:8080"
  },
  "profileFiles": {
    "standalone.development": "configs/topology/standalone.development.env",
    "standalone.production": "configs/topology/standalone.production.env",
    "cloud.development": "configs/topology/cloud.development.env",
    "cloud.production": "configs/topology/cloud.production.env"
  },
  "envKeys": {
    "deploymentProfile": "SDKWORK_GAMES_DEPLOYMENT_PROFILE",
    "environment": "SDKWORK_GAMES_ENVIRONMENT",
    "profileId": "SDKWORK_GAMES_PROFILE_ID",
    "runtimeTarget": "SDKWORK_GAMES_RUNTIME_TARGET",
    "clientDeploymentProfile": "VITE_SDKWORK_GAMES_DEPLOYMENT_PROFILE",
    "clientRuntimeTarget": "VITE_SDKWORK_GAMES_RUNTIME_TARGET",
    "standaloneGatewayBind": "SDKWORK_GAMES_APPLICATION_PUBLIC_INGRESS_BIND",
    "clientApiGatewayBaseUrl": "VITE_SDKWORK_GAMES_PLATFORM_API_GATEWAY_HTTP_URL",
    "apiGatewayBaseUrl": "SDKWORK_GAMES_PLATFORM_API_GATEWAY_HTTP_URL"
  },
  "surfaces": {
    "application.public-ingress": {
      "connectivityPlane": "application",
      "protocols": [
        "http"
      ],
      "bindEnv": "SDKWORK_GAMES_APPLICATION_PUBLIC_INGRESS_BIND",
      "httpUrlEnv": "SDKWORK_GAMES_APPLICATION_PUBLIC_HTTP_URL",
      "clientHttpEnv": "VITE_SDKWORK_GAMES_APPLICATION_PUBLIC_HTTP_URL"
    },
    "platform.api-gateway": {
      "connectivityPlane": "platform",
      "protocols": [
        "http"
      ],
      "httpUrlEnv": "SDKWORK_GAMES_PLATFORM_API_GATEWAY_HTTP_URL",
      "clientHttpEnv": "VITE_SDKWORK_GAMES_PLATFORM_API_GATEWAY_HTTP_URL"
    }
  },
  "cloudPublicHosts": {
    "application.public-ingress": {
      "httpHost": "gameengine.sdkwork.com"
    },
    "platform.api-gateway": {
      "httpHost": "api.sdkwork.com"
    }
  },
  "database": {
    "appPrefix": "SDKWORK_GAMES"
  },
  "components": {
    "applicationServer": {
      "crate": "sdkwork-gameengine-standalone-gateway",
      "binary": "sdkwork-gameengine-standalone-gateway"
    }
  },
  "orchestration": {
    "profiles": {
      "standalone.development": {
        "processes": [
          {
            "id": "application.public-ingress",
            "crate": "sdkwork-gameengine-standalone-gateway",
            "binary": "sdkwork-gameengine-standalone-gateway",
            "required": true,
            "role": "api-standalone-gateway"
          }
        ],
        "healthSurfaces": [
          "application.public-ingress"
        ]
      },
      "cloud.development": {
        "processes": [],
        "healthSurfaces": [
          "application.public-ingress",
          "platform.api-gateway"
        ]
      },
      "cloud.production": {
        "processes": [
          {
            "id": "application.public-ingress",
            "crate": "sdkwork-gameengine-standalone-gateway",
            "binary": "sdkwork-gameengine-standalone-gateway",
            "required": true,
            "role": "api-standalone-gateway"
          }
        ],
        "healthSurfaces": [
          "application.public-ingress",
          "platform.api-gateway"
        ]
      },
      "standalone.production": {
        "processes": [
          {
            "id": "application.public-ingress",
            "crate": "sdkwork-gameengine-standalone-gateway",
            "binary": "sdkwork-gameengine-standalone-gateway",
            "required": true,
            "role": "api-standalone-gateway"
          }
        ],
        "healthSurfaces": [
          "application.public-ingress"
        ]
      }
    }
  },
  "packaging": {
    "cloudConfigFiles": [],
    "targets": [
      {
        "id": "container-noarch-cloud-container-config-bundle-tar-gz",
        "profile": "container",
        "platform": "container",
        "architecture": "noarch",
        "formats": [
          "tar.gz"
        ],
        "runner": "ubuntu-24.04",
        "outputGlob": "dist/cloud-config/sdkwork-gameengine-api-gateway-config-*.tar.gz",
        "deploymentProfile": "cloud",
        "runtimeTarget": "container",
        "variant": "config-bundle"
      }
    ]
  }
}
